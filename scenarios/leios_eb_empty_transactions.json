{
  "name": "leios_eb_empty_transactions",
  "description": "The server offers an EB via LeiosNotify then delivers an empty body via LeiosFetch. In CIP-0164 (Linear Leios) an EB body is a CBOR map { tx_hash => tx_size }; an empty map (0xa0) means the EB contains no transactions. A conforming node that fetches this body and finds an empty manifest must not vote for the EB: certifying an empty EB provides no throughput benefit and wastes committee voting weight. The block_bytes value 0xa0 is a valid CBOR empty map and is the correct wire representation of an EB with no transactions — no substitution is needed.",
  "network_magic": 42,
  "trace_output_path": "trace_leios_eb_empty_transactions.jsonl",
  "expected_outcome": "success",
  "sut_genesis_time_unix": 1783591775,
  "sut_slot_duration_ms": 1000,
  "steps": [
    {
      "kind": "listen",
      "bind_address": "0.0.0.0:3044"
    },
    {
      "kind": "accept_handshake",
      "as": "client_conn",
      "peer_id": "empty_txs_server"
    },
    {
      "kind": "serve_leios_notify",
      "on": "client_conn",
      "notifications": [
        {
          "kind": "block_offer",
          "point": "${current_slot}:abababababababababababababababababababababababababababababababab",
          "eb_size": 64
        },
        {
          "kind": "votes",
          "votes": [
            {
              "slot": "$current_slot",
              "eb_hash": "abababababababababababababababababababababababababababababababab",
              "voter_id": 1,
              "signature": "aa01"
            },
            {
              "slot": "$current_slot",
              "eb_hash": "abababababababababababababababababababababababababababababababab",
              "voter_id": 2,
              "signature": "aa02"
            },
            {
              "slot": "$current_slot",
              "eb_hash": "abababababababababababababababababababababababababababababababab",
              "voter_id": 3,
              "signature": "aa03"
            }
          ]
        }
      ]
    },
    {
      "kind": "serve_leios_fetch",
      "on": "client_conn",
      "responses": [
        {
          "on": "fetch_block",
          "send": {
            "kind": "block",
            "block_bytes": "a0"
          }
        }
      ]
    },
    {
      "kind": "close_listener"
    }
  ]
}
