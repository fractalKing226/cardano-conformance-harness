{
  "name": "leios_eb_body_hash_mismatch",
  "description": "The server offers an EB via LeiosNotify and then delivers a body via LeiosFetch whose content does not hash to the announced point. In CIP-0164 (Linear Leios) an EB body is a CBOR map { tx_hash => tx_size }; the announced point carries the blake2b-256 hash of that map. A conforming node that fetches the body and verifies the hash must reject an EB whose body hash does not match the announced identifier, and must not vote for it. The body delivered here is an empty map (0xa0), which does not hash to the abab... identifier announced in the block_offer.",
  "network_magic": 42,
  "trace_output_path": "trace_leios_eb_body_hash_mismatch.jsonl",
  "expected_outcome": "success",
  "sut_genesis_time_unix": 1783591775,
  "sut_slot_duration_ms": 1000,
  "steps": [
    {
      "kind": "listen",
      "bind_address": "0.0.0.0:3043"
    },
    {
      "kind": "accept_handshake",
      "as": "client_conn",
      "peer_id": "hash_mismatch_server"
    },
    {
      "kind": "serve_leios_notify",
      "on": "client_conn",
      "notifications": [
        {
          "kind": "block_offer",
          "point": "${current_slot}:abababababababababababababababababababababababababababababababab",
          "eb_size": 512
        },
        {
          "kind": "votes",
          "votes": [
            {
              "slot": "$current_slot",
              "eb_hash": "abababababababababababababababababababababababababababababababab",
              "voter_id": 1,
              "signature": "aa01"
            },
            {
              "slot": "$current_slot",
              "eb_hash": "abababababababababababababababababababababababababababababababab",
              "voter_id": 2,
              "signature": "aa02"
            },
            {
              "slot": "$current_slot",
              "eb_hash": "abababababababababababababababababababababababababababababababab",
              "voter_id": 3,
              "signature": "aa03"
            }
          ]
        }
      ]
    },
    {
      "kind": "serve_leios_fetch",
      "on": "client_conn",
      "responses": [
        {
          "on": "fetch_block",
          "send": {
            "kind": "block",
            "block_bytes": "a0"
          }
        }
      ]
    },
    {
      "kind": "close_listener"
    }
  ]
}
