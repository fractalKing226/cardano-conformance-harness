{
  "name": "leios_equivocating_producer",
  "description": "The server offers two EBs at the same slot but with different hashes via LeiosNotify, then delivers both bodies via LeiosFetch. In CIP-0164 (Linear Leios) equivocation is detected at the header level: two block_offers sharing the same slot from the same peer are treated as equivocated. A conforming node that receives both offers must not vote for either EB. The harness sends both offers from the same connection before the node has fetched either body, so both arrive at the LeiosNotify client before any dedup can fire. The bodies delivered via LeiosFetch are empty maps (0xa0), which is valid CIP-0164 EB body CBOR — the conformance signal is in the header-level equivocation, not the body content.",
  "network_magic": 42,
  "trace_output_path": "trace_leios_equivocating_producer.jsonl",
  "expected_outcome": "success",
  "sut_genesis_time_unix": 1783591775,
  "sut_slot_duration_ms": 1000,
  "steps": [
    {
      "kind": "listen",
      "bind_address": "0.0.0.0:3042"
    },
    {
      "kind": "accept_handshake",
      "as": "client_conn",
      "peer_id": "equivocating_producer_server"
    },
    {
      "kind": "serve_leios_notify",
      "on": "client_conn",
      "notifications": [
        {
          "kind": "block_offer",
          "point": "${current_slot}:abababababababababababababababababababababababababababababababab",
          "eb_size": 512
        },
        {
          "kind": "block_offer",
          "point": "${current_slot}:cdcdcdcdcdcdcdcdcdcdcdcdcdcdcdcdcdcdcdcdcdcdcdcdcdcdcdcdcdcdcdcd",
          "eb_size": 512
        },
        {
          "kind": "votes",
          "votes": [
            {
              "slot": "$current_slot",
              "eb_hash": "abababababababababababababababababababababababababababababababab",
              "voter_id": 1,
              "signature": "aa01"
            },
            {
              "slot": "$current_slot",
              "eb_hash": "abababababababababababababababababababababababababababababababab",
              "voter_id": 2,
              "signature": "aa02"
            },
            {
              "slot": "$current_slot",
              "eb_hash": "abababababababababababababababababababababababababababababababab",
              "voter_id": 3,
              "signature": "aa03"
            }
          ]
        },
        {
          "kind": "votes",
          "votes": [
            {
              "slot": "$current_slot",
              "eb_hash": "cdcdcdcdcdcdcdcdcdcdcdcdcdcdcdcdcdcdcdcdcdcdcdcdcdcdcdcdcdcdcdcd",
              "voter_id": 1,
              "signature": "bb01"
            },
            {
              "slot": "$current_slot",
              "eb_hash": "cdcdcdcdcdcdcdcdcdcdcdcdcdcdcdcdcdcdcdcdcdcdcdcdcdcdcdcdcdcdcdcd",
              "voter_id": 2,
              "signature": "bb02"
            },
            {
              "slot": "$current_slot",
              "eb_hash": "cdcdcdcdcdcdcdcdcdcdcdcdcdcdcdcdcdcdcdcdcdcdcdcdcdcdcdcdcdcdcdcd",
              "voter_id": 3,
              "signature": "bb03"
            }
          ]
        }
      ]
    },
    {
      "kind": "serve_leios_fetch",
      "on": "client_conn",
      "responses": [
